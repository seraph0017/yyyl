{
  "name": "yyyl-uni-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:wx:xijiao": "uni -p mp-weixin --mode xijiao",
    "dev:wx:dalonggu": "uni -p mp-weixin --mode dalonggu",
    "dev:h5:xijiao": "uni -p h5 --mode xijiao",
    "dev:h5:dalonggu": "uni -p h5 --mode dalonggu",
    "dev:tt:xijiao": "uni -p mp-toutiao --mode xijiao",
    "dev:tt:dalonggu": "uni -p mp-toutiao --mode dalonggu",
    "build:wx:xijiao": "uni build -p mp-weixin --mode xijiao",
    "build:wx:dalonggu": "uni build -p mp-weixin --mode dalonggu",
    "build:h5:xijiao": "uni build -p h5 --mode xijiao",
    "build:h5:dalonggu": "uni build -p h5 --mode dalonggu",
    "build:tt:xijiao": "uni build -p mp-toutiao --mode xijiao",
    "build:tt:dalonggu": "uni build -p mp-toutiao --mode dalonggu",
    "build:all:xijiao": "npm run build:wx:xijiao && npm run build:h5:xijiao",
    "build:all:dalonggu": "npm run build:wx:dalonggu && npm run build:h5:dalonggu",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-alpha-5000320260310001",
    "vue": "^3.4.38",
    "pinia": "^2.2.6"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.14",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000320260310001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5000320260310001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000320260310001",
    "@vue/tsconfig": "^0.5.1",
    "sass": "^1.77.8",
    "typescript": "^5.5.4",
    "vite": "5.2.8",
    "vue-tsc": "^2.1.10"
  }
}
