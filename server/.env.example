# ===========================================
# 某露营地 - 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ===========================================

# ---- 应用配置 ----
APP_NAME=一月一露
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# ---- 数据库配置 ----
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password-here@localhost:5432/yyyl
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ---- Redis配置 ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT配置 ----
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- 微信小程序配置 ----
WECHAT_APP_ID=your-wechat-app-id-here
WECHAT_APP_SECRET=your-wechat-app-secret-here

# ---- 微信支付配置 ----
WECHAT_MCH_ID=your-mch-id-here
WECHAT_API_KEY=your-api-key-here
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify

# ---- AES加密配置（敏感数据加密） ----
AES_ENCRYPTION_KEY=your-32-byte-aes-key-here-change!

# ---- CORS配置 ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ---- 日志配置 ----
LOG_LEVEL=INFO
