<!-- 我的页面 -->
<view class="page-mine">
  <!-- 用户信息区 -->
  <view class="user-header">
    <view class="user-info" wx:if="{{isLoggedIn && userInfo}}">
      <view class="user-avatar">
        <image src="{{userInfo.avatar_url}}" mode="aspectFill" wx:if="{{userInfo.avatar_url}}" />
        <text class="user-avatar__placeholder" wx:else>🏕️</text>
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickname || '露营爱好者'}}</text>
        <view class="user-tags">
          <view class="user-tag user-tag--member" wx:if="{{userInfo.is_annual_member}}">
            <text>👑 年卡会员</text>
          </view>
          <view class="user-tag" wx:if="{{userInfo.points > 0}}">
            <text>⭐ {{userInfo.points}}积分</text>
          </view>
        </view>
      </view>
      <view class="user-settings" bind:tap="onSettings">
        <text>⚙️</text>
      </view>
    </view>

    <!-- 未登录 -->
    <view class="user-login" wx:else>
      <view class="user-avatar">
        <text class="user-avatar__placeholder">👤</text>
      </view>
      <view class="user-login__content">
        <text class="user-login__title">登录后享受更多服务</text>
        <button
          class="user-login__btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >手机号快捷登录</button>
      </view>
    </view>

    <!-- 会员卡片 -->
    <view class="member-card" wx:if="{{isLoggedIn && userInfo && userInfo.is_annual_member}}">
      <view class="member-card__left">
        <text class="member-card__title">👑 年卡会员</text>
        <text class="member-card__expire">有效期至 {{userInfo.annual_card_expire_date}}</text>
      </view>
      <view class="member-card__right" bind:tap="onFuncMenuTap" data-url="/pages/member/index?tab=annual">
        <text>查看权益 ›</text>
      </view>
    </view>
  </view>

  <!-- 订单入口 -->
  <view class="order-section card">
    <view class="section-header">
      <text class="section-header__title">我的订单</text>
      <view class="section-header__more" bind:tap="onViewAllOrders">
        <text>全部订单</text>
        <text class="section-header__arrow">›</text>
      </view>
    </view>
    <view class="order-menu">
      <view
        class="order-menu__item"
        wx:for="{{orderMenus}}"
        wx:key="key"
        data-key="{{item.key}}"
        bind:tap="onOrderMenuTap"
      >
        <view class="order-menu__icon-wrap">
          <text class="order-menu__icon">{{item.icon}}</text>
          <view class="order-menu__badge" wx:if="{{item.badge > 0}}">
            <text>{{item.badge}}</text>
          </view>
        </view>
        <text class="order-menu__name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="func-section card">
    <view class="func-grid">
      <view
        class="func-item"
        wx:for="{{funcMenus}}"
        wx:key="key"
        data-url="{{item.url}}"
        bind:tap="onFuncMenuTap"
      >
        <text class="func-item__icon">{{item.icon}}</text>
        <text class="func-item__name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 员工入口 -->
  <view class="staff-entry card" wx:if="{{isStaff}}" bind:tap="onStaffEntry">
    <view class="staff-entry__left">
      <text class="staff-entry__icon">🔐</text>
      <text class="staff-entry__text">员工工作台</text>
    </view>
    <text class="staff-entry__arrow">›</text>
  </view>
</view>
