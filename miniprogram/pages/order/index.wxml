<!-- 订单列表页 -->
<view class="page-order">
  <!-- Tab筛选 -->
  <view class="order-tabs">
    <view
      class="order-tab {{activeTab === index ? 'order-tab--active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-index="{{index}}"
      bind:tap="onTabChange"
    >
      <text>{{item.name}}</text>
      <view class="order-tab__line" wx:if="{{activeTab === index}}"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card card" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bind:tap="onOrderTap">
      <!-- 订单头 -->
      <view class="order-card__header">
        <text class="order-card__no">订单号：{{item.order_no}}</text>
        <text class="order-card__status" style="color: {{statusColorMap[item.status]}}">
          {{statusTextMap[item.status]}}
        </text>
      </view>

      <!-- 订单商品 -->
      <view class="order-card__items">
        <view class="order-item" wx:for="{{item.items}}" wx:for-item="product" wx:for-index="pIndex" wx:key="id">
          <view class="order-item__image">
            <image src="{{product.cover_image}}" mode="aspectFill" wx:if="{{product.cover_image}}" />
            <view class="order-item__placeholder" wx:else>
              <text>🏕️</text>
            </view>
          </view>
          <view class="order-item__info">
            <text class="order-item__name text-ellipsis">{{product.product_name}}</text>
            <text class="order-item__date" wx:if="{{product.date}}">{{product.date}}</text>
          </view>
          <view class="order-item__right">
            <text class="order-item__price">¥{{product.actual_price}}</text>
            <text class="order-item__qty">x{{product.quantity}}</text>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-card__footer">
        <view class="order-card__total">
          <text>共{{item.items.length}}件</text>
          <text class="order-card__total-label">实付：</text>
          <text class="order-card__total-price">¥{{item.actual_amount}}</text>
        </view>
        <view class="order-card__actions" catch:tap="">
          <!-- 待支付 -->
          <block wx:if="{{item.status === 'pending_payment'}}">
            <view class="order-btn order-btn--text" data-id="{{item.id}}" catch:tap="onCancel">取消</view>
            <view class="order-btn order-btn--primary" data-id="{{item.id}}" catch:tap="onPay">去支付</view>
          </block>
          <!-- 已支付 -->
          <block wx:if="{{item.status === 'paid'}}">
            <view class="order-btn order-btn--text" data-id="{{item.id}}" catch:tap="onRefund">退款</view>
            <view class="order-btn order-btn--primary" data-id="{{item.id}}" catch:tap="onViewTicket">查看票</view>
          </block>
          <!-- 已完成 -->
          <block wx:if="{{item.status === 'completed'}}">
            <view class="order-btn order-btn--outline" data-id="{{item.id}}" catch:tap="onOrderTap">详情</view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!loading && orders.length === 0}}"
    icon="📋"
    title="暂无订单"
    description="快去预定营位，开启户外之旅吧"
    buttonText="去预定"
    bind:action="onGoShopping"
  />

  <!-- 加载状态 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
