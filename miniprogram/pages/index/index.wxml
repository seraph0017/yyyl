<!-- 首页 -->
<view class="page-index">
  <!-- 顶部品牌区 -->
  <view class="header">
    <view class="header__brand">
      <text class="header__logo">🏕️</text>
      <view class="header__title">
        <text class="header__name">一月一露</text>
        <text class="header__slogan">享受户外生活</text>
      </view>
    </view>
    <view class="header__search" bind:tap="onSearchTap">
      <text class="header__search-icon">🔍</text>
      <text class="header__search-text">搜索营位、活动、装备...</text>
    </view>
  </view>

  <!-- 轮播区 -->
  <view class="banner-section">
    <swiper
      class="banner-swiper"
      indicator-dots="{{false}}"
      autoplay
      circular
      interval="{{4000}}"
      duration="{{500}}"
      bind:change="onSwiperChange"
    >
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view
          class="banner-card"
          style="background-color: {{item.color}}"
          data-id="{{item.id}}"
          bind:tap="onBannerTap"
        >
          <image
            class="banner-card__image"
            src="{{item.image}}"
            mode="aspectFill"
            wx:if="{{item.image}}"
          />
          <view class="banner-card__content" wx:else>
            <text class="banner-card__title">{{item.title}}</text>
            <view class="banner-card__btn">
              <text>立即查看</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <!-- 自定义指示器 -->
    <view class="banner-dots">
      <view
        class="banner-dot {{swiperCurrent === index ? 'banner-dot--active' : ''}}"
        wx:for="{{banners}}"
        wx:key="id"
      ></view>
    </view>
  </view>

  <!-- 分类导航 -->
  <view class="category-nav">
    <view class="section-title">
      <text class="section-title__text">探索露营</text>
    </view>
    <view class="category-grid">
      <view
        class="category-item"
        wx:for="{{categories}}"
        wx:key="key"
        data-key="{{item.key}}"
        bind:tap="onCategoryTap"
      >
        <view class="category-item__icon">
          <text>{{item.icon}}</text>
        </view>
        <text class="category-item__name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 热门推荐 -->
  <view class="recommend-section">
    <view class="section-title">
      <text class="section-title__text">🔥 热门推荐</text>
      <view class="section-title__more" bind:tap="onViewMore">
        <text>查看更多</text>
        <text class="section-title__arrow">›</text>
      </view>
    </view>

    <!-- 双列瀑布流 -->
    <view class="product-grid" wx:if="{{!loading}}">
      <view class="product-grid__col">
        <product-card
          wx:for="{{recommendProducts}}"
          wx:if="{{index % 2 === 0}}"
          wx:key="id"
          product="{{item}}"
          mode="grid"
        />
      </view>
      <view class="product-grid__col">
        <product-card
          wx:for="{{recommendProducts}}"
          wx:if="{{index % 2 === 1}}"
          wx:key="id"
          product="{{item}}"
          mode="grid"
        />
      </view>
    </view>

    <!-- 加载骨架屏 -->
    <view class="product-grid" wx:if="{{loading}}">
      <view class="product-grid__col">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="skeleton-image"></view>
          <view class="skeleton-text"></view>
          <view class="skeleton-text skeleton-text--short"></view>
        </view>
      </view>
      <view class="product-grid__col">
        <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
          <view class="skeleton-image"></view>
          <view class="skeleton-text"></view>
          <view class="skeleton-text skeleton-text--short"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="safe-bottom" style="height: 20rpx;"></view>
</view>
