<!-- 购物车页 -->
<view class="page-cart">
  <!-- 顶部操作栏 -->
  <view class="cart-header" wx:if="{{cartItems.length > 0}}">
    <text class="cart-header__count">共 {{cartItems.length}} 件商品</text>
    <text class="cart-header__edit" bind:tap="onToggleEdit">
      {{editing ? '完成' : '管理'}}
    </text>
  </view>

  <!-- 商品列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item card" wx:for="{{cartItems}}" wx:key="id">
      <!-- 选择框 -->
      <view class="cart-item__check" data-index="{{index}}" bind:tap="onToggleItem">
        <view class="checkbox {{item.selected ? 'checkbox--checked' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>

      <!-- 商品图片 -->
      <view class="cart-item__image">
        <image src="{{item.cover_image}}" mode="aspectFill" wx:if="{{item.cover_image}}" />
        <view class="cart-item__placeholder" wx:else>
          <text>🛒</text>
        </view>
      </view>

      <!-- 商品信息 -->
      <view class="cart-item__info">
        <text class="cart-item__name text-ellipsis-2">{{item.product_name}}</text>
        <view class="cart-item__bottom">
          <price-tag price="{{item.price}}" size="small" />
          <view class="cart-item__quantity">
            <view class="qty-btn {{item.quantity <= 1 ? 'qty-btn--disabled' : ''}}" data-index="{{index}}" bind:tap="onMinus">
              <text>−</text>
            </view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn {{item.quantity >= item.stock ? 'qty-btn--disabled' : ''}}" data-index="{{index}}" bind:tap="onAdd">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 删除按钮（编辑模式） -->
      <view class="cart-item__delete" wx:if="{{editing}}" data-index="{{index}}" bind:tap="onDelete">
        <text>🗑️</text>
      </view>
    </view>
  </view>

  <!-- 空购物车 -->
  <empty-state
    wx:if="{{!loading && cartItems.length === 0}}"
    icon="🛒"
    title="购物车空空如也"
    description="去逛逛营地小商店和周边商品吧"
    buttonText="去逛逛"
    bind:action="onGoShopping"
  />

  <!-- 底部结算栏 -->
  <view class="cart-footer safe-bottom" wx:if="{{cartItems.length > 0}}">
    <view class="cart-footer__left">
      <view class="cart-footer__check" bind:tap="onToggleAll">
        <view class="checkbox {{allSelected ? 'checkbox--checked' : ''}}">
          <text wx:if="{{allSelected}}">✓</text>
        </view>
        <text class="cart-footer__check-text">全选</text>
      </view>
    </view>

    <view class="cart-footer__right" wx:if="{{!editing}}">
      <view class="cart-footer__total">
        <text class="cart-footer__total-label">合计：</text>
        <text class="cart-footer__total-symbol">¥</text>
        <text class="cart-footer__total-price">{{totalPrice}}</text>
      </view>
      <view class="cart-footer__btn {{totalCount === 0 ? 'cart-footer__btn--disabled' : ''}}" bind:tap="onCheckout">
        <text>结算({{totalCount}})</text>
      </view>
    </view>

    <view class="cart-footer__right" wx:if="{{editing}}">
      <view class="cart-footer__delete-btn" bind:tap="onBatchDelete">
        <text>删除</text>
      </view>
    </view>
  </view>
</view>
